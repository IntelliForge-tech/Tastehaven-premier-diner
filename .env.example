# Copy this file to .env and fill in your Supabase project's values.
# Find both in: Supabase Dashboard -> Project Settings -> API.

# Project URL, e.g. https://abcdefghijklm.supabase.co
VITE_SUPABASE_URL=

# The "anon" / "public" API key — safe to expose to the browser.
# Do NOT put the service_role key in this project; it is never used
# by this app's client or server integration.
VITE_SUPABASE_ANON_KEY=
